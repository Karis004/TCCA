# MongoDB connection. Use your own database in production.
# Examples:
# MONGODB_URI=mongodb+srv://user:password@example.mongodb.net
# MONGODB_URI=mongodb://host.docker.internal:27017
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=tcca

# OpenAI-compatible AI API.
AI_API_BASE_URL=https://api.openai.com/v1
AI_API_KEY=replace_me
AI_MODEL=gpt-4.1-mini

# Exchange rate API.
# Default endpoint works without a key. Set FX_API_KEY only if you use ExchangeRate-API's keyed endpoint.
FX_API_BASE_URL=https://open.er-api.com/v6/latest
FX_API_KEY=
